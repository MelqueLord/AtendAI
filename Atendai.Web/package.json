{
    "name":  "atendai-web",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "typecheck":  "tsc -b --pretty false",
                    "check":  "npm run validate",
                    "lint":  "eslint .",
                    "test":  "vitest --config vitest.config.mjs --configLoader runner",
                    "test:run":  "vitest run --config vitest.config.mjs --configLoader runner",
                    "validate":  "npm run lint \u0026\u0026 npm run typecheck \u0026\u0026 npm run test:run"
                },
    "dependencies":  {
                         "@microsoft/signalr":  "^10.0.0",
                         "@tailwindcss/vite":  "^4.2.1",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "tailwindcss":  "^4.2.1"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^9.39.4",
                            "@testing-library/jest-dom":  "^6.9.1",
                            "@testing-library/react":  "^16.3.2",
                            "@testing-library/user-event":  "^14.6.1",
                            "@types/react":  "^18.3.11",
                            "@types/react-dom":  "^18.3.1",
                            "@vitejs/plugin-react":  "^4.5.0",
                            "eslint":  "^9.39.4",
                            "eslint-plugin-react-hooks":  "^7.0.1",
                            "eslint-plugin-react-refresh":  "^0.5.2",
                            "globals":  "^17.4.0",
                            "jsdom":  "^29.0.0",
                            "typescript":  "^5.9.3",
                            "typescript-eslint":  "^8.57.0",
                            "vite":  "^6.4.0",
                            "vitest":  "^4.1.0"
                        },
    "engines":  {
                    "node":  "\u003e=20.0.0"
                }
}
